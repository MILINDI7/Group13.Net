@model ThirteenthAvenue.Models.Event

@{
    ViewData["Title"] = "Delete Event";
}

<div class="container py-4">
    <h2 class="mb-3">Delete Event</h2>

    <div class="alert alert-warning">
        Are you sure you want to delete this event?
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <h4 class="card-title">@Model.Title</h4>

            <p><strong>Category:</strong> @Model.Category?.Name</p>
            <p><strong>City:</strong> @Model.City</p>
            <p><strong>Venue:</strong> @Model.Venue</p>
            <p><strong>Date:</strong> @Model.EventDate.ToString("dd MMM yyyy")</p>
            <p><strong>Status:</strong> @Model.Status</p>
        </div>
    </div>

    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
        <button type="submit" class="btn btn-danger">
            Confirm Delete
        </button>

        <a asp-action="MyEvents" class="btn btn-secondary">
            Cancel
        </a>
    </form>
</div>