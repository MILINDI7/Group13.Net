@model ThirteenthAvenue.Models.Event

@{
    ViewData["Title"] = "Event Details";
}

<h2>@Model.Title</h2>

@if (!string.IsNullOrWhiteSpace(Model.BannerImageUrl))
{
    <img src="@Model.BannerImageUrl" alt="@Model.Title" class="img-fluid mb-3" style="max-height: 350px; object-fit: cover;" />
}

<p><strong>Category:</strong> @Model.Category?.Name</p>
<p><strong>City:</strong> @Model.City</p>
<p><strong>Venue:</strong> @Model.Venue</p>
<p><strong>Date:</strong> @Model.EventDate.ToString("dd MMM yyyy")</p>
<p><strong>Time:</strong> @Model.StartTime.ToString(@"hh\:mm") - @Model.EndTime.ToString(@"hh\:mm")</p>
<p><strong>Description:</strong></p>
<p>@Model.Description</p>

@if (Model.OrganizerProfile?.VerificationStatus != ThirteenthAvenue.Models.Enums.VerificationStatus.Verified)
{
    <div class="alert alert-warning mt-3">
        This organizer has not yet been verified by 13th Avenue.
    </div>
}

@if (Model.TicketTypes.Any())
{
    <h4 class="mt-4">Tickets</h4>
    <div class="table-responsive">
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Ticket Type</th>
                    <th>Price</th>
                    <th>Available</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ticket in Model.TicketTypes)
                {
                    <tr>
                        <td>@ticket.Name</td>
                        <td>@ticket.Price</td>
                        <td>@ticket.QuantityAvailable</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TicketTypes.Any())
    {
        <a asp-controller="Booking" asp-action="Create" asp-route-eventId="@Model.Id" class="btn btn-primary mt-3">
            Book Tickets
        </a>
    }
}
else
{
    <p class="mt-4">No ticket types available for this event yet.</p>
}