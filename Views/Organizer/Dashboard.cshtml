@using System.Text.Json
@model ThirteenthAvenue.ViewModels.OrganizerDashboardViewModel

@{
    ViewData["Title"] = "Organizer Dashboard";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">@Model.BusinessName Dashboard</h2>

            <p class="text-muted mb-0">
                Status:
                @if (Model.VerificationStatus == "Verified")
                {
                    <span class="badge bg-success">Pending</span>
                }
                else if (Model.VerificationStatus == "Pending")
                {
                    <span class="badge bg-warning text-dark">Pending</span>
                }
                else
                {
                    <span class="badge bg-danger">@Model.VerificationStatus</span>
                }
            </p>
        </div>

        <a asp-controller="Event" asp-action="Create" class="btn btn-primary">
            + Create Event
        </a>
    </div>

    <!-- STATS -->
    <div class="row mb-4">

        <div class="col-md-3">
            <div class="card shadow-sm p-3">
                <h6 class="text-muted">Total Events</h6>
                <h3 class="fw-bold">@Model.TotalEvents</h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm p-3">
                <h6 class="text-muted">Tickets Sold</h6>
                <h3 class="fw-bold">@Model.TotalTicketsSold</h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm p-3">
                <h6 class="text-muted">Total Revenue</h6>
                <h3 class="fw-bold">@Model.TotalRevenue.ToString("N0") RWF</h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm p-3">
                <h6 class="text-muted">Your Earnings</h6>
                <h3 class="fw-bold text-success">@Model.OrganizerRevenue.ToString("N0") RWF</h3>
            </div>
        </div>

    </div>

    <!-- ANALYTICS -->
    <div class="card shadow-sm mb-5 p-4">
        <h5 class="mb-3 fw-bold">Revenue Over Time</h5>

        <canvas id="revenueChart" height="100"></canvas>
    </div>

    <!-- EVENTS -->
    <div class="card shadow-sm p-4">
        <h5 class="mb-3 fw-bold">My Events</h5>

        @if (Model.Events.Any())
        {
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Date</th>
                        <th>City</th>
                        <th>Status</th>
                        <th>Revenue</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ev in Model.Events)
                    {
                        <tr>
                            <td>@ev.Title</td>
                            <td>@ev.EventDate.ToString("dd MMM yyyy")</td>
                            <td>@ev.City</td>

                            <td>
                                @if (ev.IsApproved)
                                {
                                    <span class="badge bg-success">Published</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Draft</span>
                                }
                            </td>

                            <td>@ev.TotalRevenue.ToString("N0") RWF</td>

                            <td>
                                <a asp-controller="Event" asp-action="Edit" asp-route-id="@ev.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    Edit
                                </a>

                                <a asp-controller="Event" asp-action="Details" asp-route-id="@ev.Id"
                                   class="btn btn-sm btn-outline-secondary">
                                    View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p>No events created yet.</p>
        }
    </div>

</div>

<!-- CHART SCRIPT -->
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const labels = @Html.Raw(JsonSerializer.Serialize(Model.ChartLabels));
        const data = @Html.Raw(JsonSerializer.Serialize(Model.ChartData));

        new Chart(document.getElementById('revenueChart'), {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Revenue (RWF)',
                    data: data,
                    borderWidth: 2,
                    fill: true,
                    tension: 0.3
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        display: true
                    }
                }
            }
        });
    </script>
}