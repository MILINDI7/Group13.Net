@using Microsoft.AspNetCore.Identity
@using ThirteenthAvenue.Models

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        @if (User.IsInRole("Admin"))
        {
            <li class="nav-item">
                <a class="nav-link text-dark" asp-controller="Admin" asp-action="Dashboard">Admin Dashboard</a>
            </li>
        }

        @if (User.IsInRole("Organizer"))
        {
            <li class="nav-item">
                <a class="nav-link text-dark" asp-controller="Organizer" asp-action="Dashboard">Organizer Dashboard</a>
            </li>
        }

        @if (User.IsInRole("Moderator"))
        {
            <li class="nav-item">
                <a class="nav-link text-dark" asp-controller="Moderator" asp-action="Dashboard">Moderator Dashboard</a>
            </li>
        }

        @if (User.IsInRole("Client"))
        {
            <li class="nav-item">
                <a class="nav-link text-dark" asp-controller="Client" asp-action="Dashboard">Client Dashboard</a>
            </li>
        }

        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Manage/Index">
                Hello @User.Identity?.Name!
            </a>
        </li>

        <li class="nav-item">
            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index", new { area = "" })">
                <button type="submit" class="nav-link btn btn-link text-dark">Logout</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Register">Register</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Login</a>
        </li>
    }
</ul>